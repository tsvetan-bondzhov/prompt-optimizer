# Prompt Optimizer — environment configuration
# Copy to ".env" and adjust as needed. All values below are the defaults.

# --- MongoDB ---------------------------------------------------------------
# Mongo connection URI (use mongodb://localhost:27017 for local dev outside Docker)
MONGO_URI=mongodb://mongo:27017
# Database name
MONGO_DB=prompt_optimizer

# --- Active registry implementations ---------------------------------------
# Default executor when a test case does not select one (executors are chosen
# per test case in the UI: 'default' or 'template')
ACTIVE_EXECUTOR=default
# Registry key for the active PromptOptimizer
ACTIVE_OPTIMIZER=claude_code
# Registry key for the active Summarizer
ACTIVE_SUMMARIZER=default
# Default LLMRunner; test cases/prompts can select their own runner
# ('claude_code', 'ollama', or 'fake')
ACTIVE_LLM_RUNNER=claude_code

# --- Claude Code CLI -------------------------------------------------------
# Path to the Claude Code CLI executable
CLAUDE_CLI_PATH=claude

# --- Ollama (local) ---------------------------------------------------------
# Base URL of the local Ollama server (used by the 'ollama' LLM runner)
OLLAMA_BASE_URL=http://localhost:11434
# Model name passed to Ollama's /api/generate
OLLAMA_MODEL=mistral
# Request timeout in seconds
OLLAMA_TIMEOUT_SECONDS=120

# --- Optimization / evaluation defaults ------------------------------------
# Number of executions per test case (N)
DEFAULT_EXECUTIONS_PER_TEST_CASE=1
# Loop stop threshold (target average score)
DEFAULT_TARGET_SCORE=9.0
# Loop stop limit (max iterations)
DEFAULT_MAX_ITERATIONS=10

# --- JSON graders ------------------------------------------------------------
# When true, the JSON graders tolerate output wrapped in a Markdown
# code fence (```json ... ```). Default: false — pure JSON is expected and
# fenced output scores 1.
JSON_EVAL_ALLOW_MARKDOWN=false

# --- Optimizer prompt ------------------------------------------------------
# System prompt used by the prompt optimizer. Leave unset to use the built-in
# default constant defined in app/config.py.
# OPTIMIZER_SYSTEM_PROMPT=

# --- Logging ---------------------------------------------------------------
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
