# Prompt Optimizer — environment configuration
# Copy to ".env" and adjust as needed. All values below are the defaults.

# --- MongoDB ---------------------------------------------------------------
# Mongo connection URI (use mongodb://localhost:27017 for local dev outside Docker)
MONGO_URI=mongodb://mongo:27017
# Database name
MONGO_DB=prompt_optimizer

# --- Active registry implementations ---------------------------------------
# Registry key for the active PromptExecutor
ACTIVE_EXECUTOR=default
# Registry key for the active PromptImprover
ACTIVE_IMPROVER=claude_code
# Registry key for the active Summarizer
ACTIVE_SUMMARIZER=default
# Registry key for the active LLMRunner
ACTIVE_LLM_RUNNER=claude_code

# --- Claude Code CLI -------------------------------------------------------
# Path to the Claude Code CLI executable
CLAUDE_CLI_PATH=claude

# --- Optimization / evaluation defaults ------------------------------------
# Number of executions per test case (N)
DEFAULT_EXECUTIONS_PER_TEST_CASE=1
# Loop stop threshold (target average score)
DEFAULT_TARGET_SCORE=9.0
# Loop stop limit (max iterations)
DEFAULT_MAX_ITERATIONS=10

# --- Optimizer prompt ------------------------------------------------------
# System prompt used by the prompt improver. Leave unset to use the built-in
# default constant defined in app/config.py.
# IMPROVER_SYSTEM_PROMPT=

# --- Logging ---------------------------------------------------------------
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
